# macOS
.DS_Store

# Environment and secrets
.env
.env.*
!.env.example
config/master.key
config/credentials.yml.enc
config/credentials/*.key

# Logs and temp files
log/*
tmp/*
!/log/.keep
!/tmp/.keep
!/tmp/pids/
tmp/pids/*
!/tmp/pids/.keep

# Rails/build artifacts
node_modules/
storage/*
!/storage/.keep
tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep
app/assets/builds/*
!/app/assets/builds/.keep
public/assets/
public/packs/
public/vite/
.bundle/
