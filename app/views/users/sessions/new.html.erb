<section class="mx-auto max-w-md rounded-md border border-slate-200 bg-white p-8 shadow-sm">
  <h1 class="text-2xl font-semibold tracking-tight">Sign in with Google</h1>
  <p class="mt-3 text-sm leading-6 text-slate-600">Use your Google account to submit tickets and vote on the roadmap.</p>

  <% if ENV["GOOGLE_CLIENT_ID"].present? && ENV["GOOGLE_CLIENT_SECRET"].present? %>
    <%= button_to "Continue with Google", omniauth_authorize_path(:user, :google_oauth2), data: { turbo: false }, class: "mt-6 w-full rounded-md bg-slate-900 px-4 py-3 text-sm font-semibold text-white hover:bg-slate-700" %>
  <% else %>
    <p class="mt-6 rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">Google sign-in is not configured yet.</p>
  <% end %>
</section>
