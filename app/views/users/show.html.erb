<% content_for :title, @user.username %>

<div class="space-y-8">
  <section class="flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-emerald-700">User</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight"><%= @user.display_username %></h1>
      <p class="mt-1 text-sm text-slate-500">@<%= @user.username %></p>
    </div>
    <% if current_user == @user %>
      <%= link_to "Edit username", edit_profile_path, class: "rounded-md border border-slate-300 bg-white px-4 py-3 text-sm font-semibold text-slate-900 hover:border-slate-400" %>
    <% end %>
  </section>

  <section class="grid gap-4 md:grid-cols-4">
    <div class="rounded-md border border-slate-200 bg-white p-5">
      <p class="text-sm font-medium text-slate-500">Karma</p>
      <p class="mt-2 text-3xl font-semibold"><%= @user.karma_score %></p>
    </div>
    <div class="rounded-md border border-slate-200 bg-white p-5">
      <p class="text-sm font-medium text-slate-500">Public tickets</p>
      <p class="mt-2 text-3xl font-semibold"><%= @public_ticket_count %></p>
    </div>
    <div class="rounded-md border border-slate-200 bg-white p-5">
      <p class="text-sm font-medium text-slate-500">Votes received</p>
      <p class="mt-2 text-3xl font-semibold"><%= @votes_received_count %></p>
    </div>
    <div class="rounded-md border border-slate-200 bg-white p-5">
      <p class="text-sm font-medium text-slate-500">Comments</p>
      <p class="mt-2 text-3xl font-semibold"><%= @comment_count %></p>
    </div>
  </section>

  <section>
    <h2 class="mb-3 text-lg font-semibold">Karma breakdown</h2>
    <div class="grid gap-3 rounded-md border border-slate-200 bg-white p-4 sm:grid-cols-2 lg:grid-cols-3">
      <% @karma_breakdown.each do |label, points| %>
        <div class="flex items-center justify-between gap-4 rounded-md bg-slate-50 px-3 py-2">
          <span class="text-sm font-medium text-slate-600"><%= label.to_s.humanize %></span>
          <span class="text-sm font-semibold text-slate-950"><%= points %></span>
        </div>
      <% end %>
    </div>
  </section>

  <section>
    <h2 class="mb-3 text-lg font-semibold">Tickets</h2>
    <div class="divide-y divide-slate-200 rounded-md border border-slate-200 bg-white">
      <% if @tickets.any? %>
        <% @tickets.each do |ticket| %>
          <%= link_to ticket, class: "block p-4 hover:bg-slate-50" do %>
            <div class="flex items-center justify-between gap-4">
              <p class="font-medium"><%= ticket.title %></p>
              <span class="shrink-0 rounded bg-slate-100 px-2 py-1 text-xs font-medium text-slate-700"><%= pluralize(ticket.votes_count, "vote") %></span>
            </div>
            <p class="mt-1 text-sm text-slate-600"><%= ticket.status.humanize %></p>
          <% end %>
        <% end %>
      <% else %>
        <p class="p-4 text-sm text-slate-600">No public tickets yet.</p>
      <% end %>
    </div>
  </section>

  <section>
    <h2 class="mb-3 text-lg font-semibold">Recent comments</h2>
    <div class="divide-y divide-slate-200 rounded-md border border-slate-200 bg-white">
      <% if @comments.any? %>
        <% @comments.each do |comment| %>
          <%= link_to comment.ticket, class: "block p-4 hover:bg-slate-50" do %>
            <p class="text-sm font-medium text-slate-950"><%= comment.ticket.title %></p>
            <p class="mt-1 text-sm text-slate-600"><%= truncate(comment.body, length: 180) %></p>
          <% end %>
        <% end %>
      <% else %>
        <p class="p-4 text-sm text-slate-600">No public comments yet.</p>
      <% end %>
    </div>
  </section>
</div>
