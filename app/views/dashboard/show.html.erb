<div class="space-y-8">
  <div class="flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
    <div>
      <h1 class="text-3xl font-semibold tracking-tight">Dashboard</h1>
      <p class="mt-2 text-slate-600">Ticket priority, voting activity, and your recent requests.</p>
    </div>
    <%= link_to "New ticket", new_ticket_path, class: "rounded-md bg-slate-900 px-4 py-3 text-sm font-semibold text-white hover:bg-slate-700" %>
  </div>

  <section class="grid gap-4 md:grid-cols-3">
    <div class="rounded-md border border-slate-200 bg-white p-5">
      <p class="text-sm font-medium text-slate-500">Open work</p>
      <p class="mt-2 text-3xl font-semibold"><%= @open_ticket_count %></p>
    </div>
    <div class="rounded-md border border-slate-200 bg-white p-5">
      <p class="text-sm font-medium text-slate-500">Votes cast</p>
      <p class="mt-2 text-3xl font-semibold"><%= @vote_count %></p>
    </div>
    <div class="rounded-md border border-slate-200 bg-white p-5">
      <p class="text-sm font-medium text-slate-500">Your activity</p>
      <p class="mt-2 text-3xl font-semibold"><%= @usage_events.values.sum %></p>
    </div>
  </section>

  <section class="grid gap-6 lg:grid-cols-2">
    <div>
      <h2 class="mb-3 text-lg font-semibold">Billing</h2>
      <div class="space-y-4 rounded-md border border-slate-200 bg-white p-5">
        <div>
          <p class="text-sm font-medium text-slate-500">Current plan</p>
          <p class="mt-1 text-lg font-semibold"><%= @subscription&.plan&.humanize || "Free" %></p>
          <p class="mt-1 text-sm text-slate-600"><%= @subscription&.status&.humanize || "No paid plan yet" %></p>
        </div>

        <div class="flex flex-wrap gap-3">
          <% @billing_offers.each_with_index do |offer, index| %>
            <%= button_to offer.button_label, billing_checkout_path(kind: offer.key), method: :post, class: "#{index.zero? ? "bg-slate-900 text-white hover:bg-slate-700" : "border border-slate-300 bg-white text-slate-900 hover:border-slate-400"} rounded-md px-4 py-3 text-sm font-semibold" %>
          <% end %>
        </div>

        <% unless @billing_offers.any? %>
          <p class="rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">Stripe checkout offers are not configured yet.</p>
        <% end %>
      </div>
    </div>

    <div>
      <h2 class="mb-3 text-lg font-semibold">Top tickets</h2>
      <div class="divide-y divide-slate-200 rounded-md border border-slate-200 bg-white">
        <% @tickets.each do |ticket| %>
          <%= link_to ticket, class: "block p-4 hover:bg-slate-50" do %>
            <div class="flex items-center justify-between gap-4">
              <p class="font-medium"><%= ticket.title %></p>
              <span class="rounded bg-slate-100 px-2 py-1 text-xs font-medium text-slate-700"><%= pluralize(ticket.votes_count, "vote") %></span>
            </div>
            <p class="mt-1 text-sm text-slate-600"><%= truncate(ticket.description, length: 120) %></p>
          <% end %>
        <% end %>
      </div>
    </div>

    <div>
      <h2 class="mb-3 text-lg font-semibold">Your tickets</h2>
      <div class="divide-y divide-slate-200 rounded-md border border-slate-200 bg-white">
        <% @my_tickets.each do |ticket| %>
          <%= link_to ticket, class: "block p-4 hover:bg-slate-50" do %>
            <div class="flex items-center justify-between gap-4">
              <p class="font-medium"><%= ticket.title %></p>
              <span class="rounded bg-slate-100 px-2 py-1 text-xs font-medium text-slate-700"><%= ticket.status.humanize %></span>
            </div>
            <p class="mt-1 text-sm text-slate-600"><%= truncate(ticket.description, length: 120) %></p>
          <% end %>
        <% end %>
      </div>
    </div>
  </section>
</div>
