<section class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
  <div>
    <p class="text-sm font-semibold uppercase tracking-wide text-emerald-700">Product feedback for loom</p>
    <h1 class="mt-3 max-w-3xl text-5xl font-semibold tracking-tight text-slate-950">Collect tickets, vote on priorities, and keep the roadmap focused.</h1>
    <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-700">
      Share feature requests and bugs, see what other users care about, and help decide what should be built next.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <%= link_to "Browse tickets", tickets_path, class: "rounded-md border border-slate-300 bg-white px-4 py-3 text-sm font-semibold text-slate-900 hover:border-slate-400" %>
      <%= link_to "Recent tickets", recent_tickets_path, class: "rounded-md border border-slate-300 bg-white px-4 py-3 text-sm font-semibold text-slate-900 hover:border-slate-400" %>
      <% if user_signed_in? %>
        <%= link_to "Open dashboard", dashboard_path, class: "rounded-md bg-slate-900 px-4 py-3 text-sm font-semibold text-white hover:bg-slate-700" %>
        <%= link_to "Create ticket", new_ticket_path, class: "rounded-md border border-slate-300 bg-white px-4 py-3 text-sm font-semibold text-slate-900 hover:border-slate-400" %>
      <% else %>
        <%= link_to "Sign in with Google", new_user_session_path, class: "rounded-md bg-slate-900 px-4 py-3 text-sm font-semibold text-white hover:bg-slate-700" %>
      <% end %>
    </div>
  </div>

  <div class="grid gap-4">
    <div class="rounded-md border border-slate-200 bg-white p-5">
      <p class="text-sm font-medium text-slate-500">Tickets captured</p>
      <p class="mt-2 text-4xl font-semibold"><%= @ticket_count %></p>
    </div>
    <div class="rounded-md border border-slate-200 bg-white p-5">
      <p class="text-sm font-medium text-slate-500">Shipped requests</p>
      <p class="mt-2 text-4xl font-semibold"><%= @shipped_count %></p>
    </div>
    <div class="rounded-md border border-slate-200 bg-white p-5">
      <p class="text-sm font-medium text-slate-500">Votes cast</p>
      <p class="mt-2 text-4xl font-semibold"><%= @vote_count %></p>
    </div>
  </div>
</section>

<section class="mt-10 grid gap-6 lg:grid-cols-2">
  <div>
    <div class="mb-3 flex items-center justify-between gap-4">
      <h2 class="text-lg font-semibold">Top open tickets</h2>
      <%= link_to "View all", tickets_path, class: "text-sm font-medium text-slate-700 hover:text-slate-950" %>
    </div>
    <div class="divide-y divide-slate-200 rounded-md border border-slate-200 bg-white">
      <% if @top_tickets.any? %>
        <% @top_tickets.each do |ticket| %>
          <%= link_to ticket, class: "block p-4 hover:bg-slate-50" do %>
            <div class="flex items-center justify-between gap-4">
              <p class="font-medium"><%= ticket.title %></p>
              <span class="shrink-0 rounded bg-slate-100 px-2 py-1 text-xs font-medium text-slate-700"><%= pluralize(ticket.votes_count, "vote") %></span>
            </div>
            <p class="mt-1 text-sm text-slate-600"><%= truncate(ticket.description, length: 120) %></p>
          <% end %>
        <% end %>
      <% else %>
        <p class="p-4 text-sm text-slate-600">No public tickets yet.</p>
      <% end %>
    </div>
  </div>

  <div>
    <div class="mb-3 flex items-center justify-between gap-4">
      <h2 class="text-lg font-semibold">Recent tickets</h2>
      <%= link_to "View recent", recent_tickets_path, class: "text-sm font-medium text-slate-700 hover:text-slate-950" %>
    </div>
    <div class="divide-y divide-slate-200 rounded-md border border-slate-200 bg-white">
      <% if @recent_tickets.any? %>
        <% @recent_tickets.each do |ticket| %>
          <%= link_to ticket, class: "block p-4 hover:bg-slate-50" do %>
            <div class="flex items-center justify-between gap-4">
              <p class="font-medium"><%= ticket.title %></p>
              <span class="shrink-0 rounded bg-slate-100 px-2 py-1 text-xs font-medium text-slate-700"><%= ticket.status.humanize %></span>
            </div>
            <p class="mt-1 text-sm text-slate-600">By <%= ticket.user.display_username %></p>
          <% end %>
        <% end %>
      <% else %>
        <p class="p-4 text-sm text-slate-600">No recent tickets yet.</p>
      <% end %>
    </div>
  </div>
</section>

<section class="mt-10">
  <div class="mb-3 flex items-center justify-between gap-4">
    <h2 class="text-lg font-semibold">Recent users</h2>
  </div>
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
    <% @recent_users.each do |user| %>
      <%= link_to user_path(user), class: "rounded-md border border-slate-200 bg-white p-4 hover:bg-slate-50" do %>
        <p class="font-medium text-slate-950"><%= user.display_username %></p>
        <p class="mt-1 text-sm text-slate-500">@<%= user.username %></p>
        <p class="mt-3 text-sm font-semibold text-slate-700"><%= pluralize(user.karma_score, "karma point") %></p>
      <% end %>
    <% end %>
  </div>
</section>
