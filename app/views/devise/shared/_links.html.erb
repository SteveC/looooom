<%- if controller_name != "sessions" %>
  <p class="mt-4 text-sm font-medium text-slate-700"><%= link_to "Log in", new_session_path(resource_name), class: "hover:text-slate-950" %></p>
<% end %>

<%- if devise_mapping.registerable? && controller_name != "registrations" %>
  <p class="mt-2 text-sm font-medium text-slate-700"><%= link_to "Sign up", new_registration_path(resource_name), class: "hover:text-slate-950" %></p>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
  <p class="mt-2 text-sm font-medium text-slate-700"><%= link_to "Forgot your password?", new_password_path(resource_name), class: "hover:text-slate-950" %></p>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != "confirmations" %>
  <p class="mt-2 text-sm font-medium text-slate-700"><%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name), class: "hover:text-slate-950" %></p>
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != "unlocks" %>
  <p class="mt-2 text-sm font-medium text-slate-700"><%= link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name), class: "hover:text-slate-950" %></p>
<% end %>

<%- if devise_mapping.omniauthable? %>
  <% providers = [] %>
  <% providers << :google_oauth2 if ENV["GOOGLE_CLIENT_ID"].present? && ENV["GOOGLE_CLIENT_SECRET"].present? %>
  <% providers << :github if ENV["GITHUB_CLIENT_ID"].present? && ENV["GITHUB_CLIENT_SECRET"].present? %>

  <% providers.each do |provider| %>
    <p class="mt-2">
      <%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-50" %>
    </p>
  <% end %>
<% end %>
