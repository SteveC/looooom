<% content_for :title, "Edit profile" %>

<div class="max-w-2xl">
  <h1 class="text-3xl font-semibold tracking-tight">Edit profile</h1>
  <p class="mt-2 text-slate-600">Choose the public username shown on tickets, comments, and your profile page.</p>

  <div class="mt-6 rounded-md border border-slate-200 bg-white p-5">
    <% if @user.username_change_available? %>
      <%= form_with(model: @user, url: profile_path, method: :patch, class: "contents") do |form| %>
        <% if @user.errors.any? %>
          <div class="mb-5 rounded-md bg-red-50 px-3 py-2 text-red-600">
            <h2 class="font-medium"><%= pluralize(@user.errors.count, "error") %> stopped your profile from being saved:</h2>
            <ul class="ml-6 mt-2 list-disc text-sm">
              <% @user.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="my-5">
          <%= form.label :username, class: "text-sm font-medium text-slate-700" %>
          <%= form.text_field :username, class: ["mt-2 block w-full rounded-md border px-3 py-2 shadow-sm", {"border-slate-300 focus:outline-emerald-600": @user.errors[:username].none? && @user.errors[:slug].none?, "border-red-400 focus:outline-red-600": @user.errors[:username].any? || @user.errors[:slug].any?}], placeholder: "heavy banana 56" %>
          <p class="mt-2 text-sm text-slate-500">You can change this once. Spaces become hyphens in your public URL.</p>
        </div>

        <div class="flex flex-wrap gap-3">
          <%= form.submit "Save username", class: "cursor-pointer rounded-md bg-slate-900 px-4 py-3 text-sm font-semibold text-white hover:bg-slate-700" %>
          <%= link_to "Cancel", user_path(@user), class: "rounded-md border border-slate-300 bg-white px-4 py-3 text-sm font-semibold text-slate-900 hover:border-slate-400" %>
        </div>
      <% end %>
    <% else %>
      <p class="rounded-md border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">Your username has already been changed once.</p>
      <div class="mt-4">
        <%= link_to "View public profile", user_path(@user), class: "rounded-md bg-slate-900 px-4 py-3 text-sm font-semibold text-white hover:bg-slate-700" %>
      </div>
    <% end %>
  </div>
</div>
