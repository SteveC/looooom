<div class="mt-6 rounded-md border border-slate-200 bg-white p-4">
  <%= form_with url: path, method: :get, class: "flex flex-col gap-3 sm:flex-row" do |form| %>
    <%= form.search_field :q, value: @query, placeholder: "Search tickets", class: "min-w-0 flex-1 rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:outline-emerald-600" %>
    <%= form.submit "Search", class: "cursor-pointer rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700" %>
    <% if @query.present? %>
      <%= link_to "Clear", path, class: "rounded-md border border-slate-300 bg-white px-4 py-2 text-center text-sm font-semibold text-slate-900 hover:border-slate-400" %>
    <% end %>
  <% end %>

  <div class="mt-4 flex flex-wrap gap-3 text-sm font-medium">
    <%= link_to "Top open", tickets_path(q: @query.presence), class: "text-slate-700 hover:text-slate-950" %>
    <%= link_to "Recent", recent_tickets_path(q: @query.presence), class: "text-slate-700 hover:text-slate-950" %>
    <%= link_to "Closed", closed_tickets_path(q: @query.presence), class: "text-slate-700 hover:text-slate-950" %>
  </div>
</div>
