<% content_for :title, @ticket.title %>

<article class="max-w-3xl">
  <div class="mb-6 flex flex-wrap gap-2">
    <span class="rounded bg-slate-100 px-2 py-1 text-xs font-medium text-slate-700"><%= @ticket.status.humanize %></span>
    <span class="rounded bg-emerald-50 px-2 py-1 text-xs font-medium text-emerald-800"><%= @ticket.priority.humanize %></span>
    <span class="rounded bg-indigo-50 px-2 py-1 text-xs font-medium text-indigo-800"><%= pluralize(@ticket.votes_count, "vote") %></span>
  </div>

  <h1 class="text-3xl font-semibold tracking-tight"><%= @ticket.title %></h1>
  <p class="mt-2 text-sm text-slate-500">Submitted <%= time_ago_in_words(@ticket.created_at) %> ago</p>

  <div class="mt-8 whitespace-pre-wrap rounded-md border border-slate-200 bg-white p-5 leading-7 text-slate-800"><%= @ticket.description %></div>

  <div class="mt-6 flex flex-wrap gap-3">
    <% if @ticket.voted_by?(current_user) %>
      <%= button_to "Remove vote", vote_ticket_path(@ticket), method: :delete, class: "rounded-md bg-slate-900 px-4 py-3 text-sm font-semibold text-white hover:bg-slate-700" %>
    <% else %>
      <%= button_to "Vote", vote_ticket_path(@ticket), method: :post, class: "rounded-md bg-slate-900 px-4 py-3 text-sm font-semibold text-white hover:bg-slate-700" %>
    <% end %>
    <% if current_user.admin? || @ticket.user == current_user %>
      <%= link_to "Edit", edit_ticket_path(@ticket), class: "rounded-md border border-slate-300 bg-white px-4 py-3 text-sm font-semibold text-slate-900 hover:border-slate-400" %>
    <% end %>
    <%= link_to "Back", tickets_path, class: "rounded-md border border-slate-300 bg-white px-4 py-3 text-sm font-semibold text-slate-900 hover:border-slate-400" %>
    <% if current_user.admin? || @ticket.user == current_user %>
      <%= button_to "Delete", @ticket, method: :delete, class: "rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm font-semibold text-red-700 hover:bg-red-100", data: { turbo_confirm: "Delete this ticket?" } %>
    <% end %>
  </div>
</article>
