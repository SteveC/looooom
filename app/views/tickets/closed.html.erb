<% content_for :title, "Closed tickets" %>

<div class="w-full">
  <div class="flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
    <div>
      <h1 class="text-3xl font-semibold tracking-tight">Closed tickets</h1>
      <p class="mt-2 text-slate-600">Shipped and closed work that can still collect reopen interest.</p>
    </div>
    <%= link_to "Open tickets", tickets_path, class: "rounded-md border border-slate-300 bg-white px-4 py-3 text-sm font-semibold text-slate-900 hover:border-slate-400" %>
  </div>

  <div id="tickets" class="mt-6 divide-y divide-slate-200 rounded-md border border-slate-200 bg-white">
    <% if @tickets.any? %>
      <% @tickets.each do |ticket| %>
        <div class="flex flex-col justify-between gap-4 p-4 sm:flex-row sm:items-center">
          <%= render ticket %>
          <%= link_to "Open", ticket, class: "rounded-md bg-slate-100 px-3.5 py-2.5 text-center text-sm font-medium hover:bg-slate-200" %>
        </div>
      <% end %>
    <% else %>
      <p class="p-8 text-center text-slate-600">No closed tickets yet.</p>
    <% end %>
  </div>
</div>
