<% content_for :title, "Closed tickets" %>

<div class="w-full">
  <div class="flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
    <div>
      <h1 class="text-3xl font-semibold tracking-tight">Closed tickets</h1>
      <p class="mt-2 text-slate-600">Shipped and closed work that can still collect reopen interest.</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <%= link_to "Top open", tickets_path, class: "rounded-md border border-slate-300 bg-white px-4 py-3 text-sm font-semibold text-slate-900 hover:border-slate-400" %>
      <%= link_to "Recent tickets", recent_tickets_path, class: "rounded-md border border-slate-300 bg-white px-4 py-3 text-sm font-semibold text-slate-900 hover:border-slate-400" %>
    </div>
  </div>

  <%= render "directory_nav", path: closed_tickets_path %>
  <%= render "ticket_list", tickets: @tickets, empty_message: @query.present? ? "No closed tickets match that search." : "No closed tickets yet." %>
</div>
