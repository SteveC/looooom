<% content_for :title, "New ticket" %>

<div class="max-w-2xl">
  <h1 class="text-3xl font-semibold tracking-tight">New ticket</h1>
  <p class="mt-2 text-slate-600">Describe a feature, bug, or improvement for the evolution loop to analyze.</p>

  <div class="mt-6 rounded-md border border-slate-200 bg-white p-5">
    <%= render "form", ticket: @ticket %>
  </div>

  <%= link_to "Back to tickets", tickets_path, class: "mt-4 inline-block text-sm font-medium text-slate-700 hover:text-slate-950" %>
</div>
