<% content_for :title, "Recent tickets" %>

<div class="w-full">
  <div class="flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
    <div>
      <h1 class="text-3xl font-semibold tracking-tight">Recent tickets</h1>
      <p class="mt-2 text-slate-600">Recently submitted accepted requests and bugs.</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <%= link_to "Top open", tickets_path, class: "rounded-md border border-slate-300 bg-white px-4 py-3 text-sm font-semibold text-slate-900 hover:border-slate-400" %>
      <% if user_signed_in? %>
        <%= link_to "New ticket", new_ticket_path, class: "rounded-md bg-slate-900 px-4 py-3 text-sm font-semibold text-white hover:bg-slate-700" %>
      <% else %>
        <%= link_to "Sign in to submit", new_user_session_path, class: "rounded-md bg-slate-900 px-4 py-3 text-sm font-semibold text-white hover:bg-slate-700" %>
      <% end %>
    </div>
  </div>

  <%= render "directory_nav", path: recent_tickets_path %>
  <%= render "ticket_list", tickets: @tickets, empty_message: @query.present? ? "No recent tickets match that search." : "No recent tickets yet." %>
</div>
